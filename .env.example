# Onside — örnek environment değişkenleri.
# Bu dosyayı `.env.local` olarak kopyalayıp gerçek değerlerle doldur.

# --- Supabase (Phase 0+) ---
# Supabase Cloud → Project → Settings → API
# Yeni naming: publishable key (browser-safe, eski "anon"un yerini aldı), secret key (server-only, eski "service_role").
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_YOUR-KEY
SUPABASE_SECRET_KEY=sb_secret_YOUR-KEY

# Drizzle / Postgres bağlantısı (server-only)
# Supabase Cloud → Project → Settings → Database → Connection string (URI, "Transaction" pooler veya "Session")
DATABASE_URL=postgresql://postgres:PASSWORD@HOST:6543/postgres?sslmode=require

# Site URL (metadataBase, OAuth callback, vs.)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Geocoding (Phase 2) ---
# Nominatim için zorunlu User-Agent (admin email ile)
NOMINATIM_USER_AGENT=Onside/1.0 contact@example.com

# --- Rate limiting (opsiyonel, production önerilir) ---
# Upstash Redis Cloud → Database → REST API → URL + Token
# Env yoksa kod in-memory fallback'a düşer (single-instance only).
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# --- Auth (Phase 1) ---
# Apple OAuth: env yoksa skip (Email + Google yeterli)
# NEXT_PUBLIC_APPLE_OAUTH=true

# --- Hata izleme (Phase 9) ---
# SENTRY_DSN=
